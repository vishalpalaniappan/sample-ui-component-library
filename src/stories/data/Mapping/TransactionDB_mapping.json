        "uid": "c821456f-ff27-470d-a8fe-79a6de2869a9",
        "start_line": 19,
        "end_line": 29,
        "source": "self.cursor.execute(\"\"\"\n        CREATE TABLE IF NOT EXISTS translation_jobs (\n            job_id   INTEGER PRIMARY KEY AUTOINCREMENT,\n            uid      TEXT NOT NULL UNIQUE,\n            english  TEXT NOT NULL,\n            french   TEXT,\n            spanish  TEXT,\n            tamil    TEXT,\n            done     INTEGER NOT NULL DEFAULT 0\n        );\n        \"\"\")"
    },
    {
        "type": "Expr",
        "uid": "b71ce3b6-d60d-4b0d-9a3b-88f0d39af32b",
        "start_line": 30,
        "end_line": 30,
        "source": "self.conn.commit()"
    },
    {
        "type": "Assign",
        "uid": "b14271fb-25bd-4a33-9788-4a132b0a1db7",
        "start_line": 33,
        "end_line": 33,
        "source": "uid = str(uuid.uuid4())"
    },
    {
        "type": "Expr",
        "uid": "3d9037de-9f3f-436e-a2fa-9f5dadab2e12",
        "start_line": 34,
        "end_line": 40,
        "source": "self.conn.execute(\n            \"\"\"\n            INSERT INTO translation_jobs (uid, english)\n            VALUES (?, ?)\n            \"\"\",\n            (uid, data)\n        )"
    },
    {
        "type": "Expr",
        "uid": "8a1a1898-6fee-4f0c-a8f3-dd0d9ce2b328",
        "start_line": 41,
        "end_line": 41,
        "source": "self.conn.commit()"
    },
    {
        "type": "Return",
        "uid": "d4b3f729-1778-4d70-bdc8-4d7aed27455d",
        "start_line": 43,
        "end_line": 46,
        "source": "return {\n            \"uid\": uid,\n            \"value\": {\"data\": data}\n        }"
    },
    {
        "type": "Expr",
        "uid": "777b1041-5b87-43c4-806e-24e553be3862",
        "start_line": 49,
        "end_line": 56,
        "source": "self.conn.execute(\n            f\"\"\"\n            UPDATE translation_jobs\n            SET {msg[\"value\"][\"language\"]} = ?\n            WHERE uid = ?\n            \"\"\",\n            (msg[\"value\"][\"translated\"], msg[\"uid\"])\n        )"
    },
    {
        "type": "Expr",
        "uid": "7787bd74-1e3e-42e1-843f-38976c63cf59",
        "start_line": 57,
        "end_line": 57,
        "source": "self.conn.commit()"
    },
    {
        "type": "Assign",
        "uid": "00dea7a4-d351-476b-b2c1-a52fb52e0352",
        "start_line": 61,
        "end_line": 71,
        "source": "cur = self.conn.execute(\n            \"\"\"\n            SELECT\n                french  IS NOT NULL\n            AND spanish IS NOT NULL\n            AND tamil   IS NOT NULL\n            FROM translation_jobs\n            WHERE uid = ?\n            \"\"\",\n            (uid,)\n        )"
    },
    {
        "type": "Assign",
        "uid": "8ea9eec3-4454-46ff-a235-a47e3c7e147e",
        "start_line": 72,
        "end_line": 72,
        "source": "row = cur.fetchone()"
    },
    {
        "type": "Return",
        "uid": "4eba8b2e-c6ab-4bf2-bddc-6794abff14fa",
        "start_line": 73,
        "end_line": 73,
        "source": "return bool(row[0]) if row else False"
    },
    {
        "type": "Expr",
