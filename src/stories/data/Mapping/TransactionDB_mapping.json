        "start_line": 76,
        "end_line": 83,
        "source": "self.conn.execute(\n            \"\"\"\n            UPDATE translation_jobs\n            SET done = 1\n            WHERE uid = ?\n            \"\"\",\n            (uid,)\n        )"
    },
